{
  "name": "valoinsight",
  "version": "0.1.0",
  "description": "Valorant teammate stats viewer - 无畏契约队友战绩查看工具",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.renderer.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder"
  },
  "keywords": [
    "valorant",
    "electron",
    "vue3"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/node": "^25.9.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vue-tsc": "^3.3.0"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "ws": "^8.20.1"
  }
}
